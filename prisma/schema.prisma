// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider        = "prisma-client"
  previewFeatures = ["relationJoins"]
  output          = "../generated"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id
  name      String
  email     String   @unique
  password  String
  createdAt DateTime
  updatedAt DateTime @updatedAt

  categories   Category[]
  fixedExpense FixedExpense[]
  incomeSource IncomeSource[]
}

model Category {
  id        String   @id
  name      String   @unique
  type      String
  color     String
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  createdAt DateTime
  updatedAt DateTime @updatedAt

  fixedExpense FixedExpense[]
  incomeSource IncomeSource[]
}

model FixedExpense {
  id         String   @id
  name       String
  amount     Float
  dueDay     Int
  isActive   Boolean
  startDate  DateTime
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  categoryId String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  userId     String
}

model IncomeSource {
  id         String   @id
  name       String
  amount     Float
  recurrence String
  isActive   Boolean
  startDate  DateTime
  endDate    DateTime
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  categoryId String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  userId     String
}
